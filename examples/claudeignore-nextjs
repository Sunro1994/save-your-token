# -----------------------------------------------
# Next.js / Node.js 프로젝트용 .claudeignore
# -----------------------------------------------
# 사용법: 프로젝트 루트에 .claudeignore 이름으로 복사
#   cp examples/claudeignore-nextjs .claudeignore
#
# Claude Code가 아래 경로를 자동 탐색하지 않습니다.
# "이 파일 읽어줘"처럼 직접 요청하면 여전히 접근 가능합니다.
# -----------------------------------------------

# 패키지 / 의존성 (수백~수천 개 파일)
node_modules/
.pnp/
.pnp.js

# 빌드 산출물
.next/
out/
dist/
build/
.turbo/

# 락 파일 (Claude가 읽어도 의미 없음)
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb
npm-debug.log*

# 환경 변수 (민감 정보)
.env
.env.*
!.env.example

# 캐시 및 임시 파일
.cache/
.swc/
.eslintcache
tsconfig.tsbuildinfo
*.tsbuildinfo

# 테스트 커버리지
coverage/
.nyc_output/

# 이미지 / 폰트 / 미디어 (바이너리)
public/
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.ico
*.svg
*.mp4
*.webm
*.woff
*.woff2
*.ttf
*.eot

# 배포 플랫폼
.vercel/
.netlify/

# IDE / 에디터
.idea/
.vscode/
*.swp
*.swo

# OS 시스템 파일
.DS_Store
Thumbs.db
desktop.ini

# Storybook
storybook-static/
